{
  "python-envs.defaultEnvManager": "ms-python.python:conda",
  "python-envs.defaultPackageManager": "ms-python.python:conda",

  "cSpell.words": [
    "acked",
    "CREAT",
    "docstrings",
    "dotenv",
    "getpid",
    "getwch",
    "Headful",
    "kbhit",
    "keypair",
    "lifecycles",
    "memlimit",
    "metor",
    "nacl",
    "opslimit",
    "pwhash",
    "pycache",
    "RDWR",
    "SALTBYTES",
    "signum",
    "SIGWINCH",
    "socksocket",
    "sqlcipher",
    "subcmd",
    "tcflush",
    "tcgetattr",
    "TCIFLUSH",
    "TCSADRAIN",
    "tcsetattr",
    "unacked",
    "urandom",
    "venv",
    "WRONLY"
  ],

  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },

  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },

  "[markdown]": {
    "editor.wordWrap": "on"
  }
}
